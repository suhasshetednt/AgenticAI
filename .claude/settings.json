{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Bash(python:*)",
      "Bash(python -m pytest:*)",
      "Bash(pytest:*)",
      "Bash(pip install:*)",
      "Bash(uvicorn:*)",
      "Bash(ruff:*)",
      "Bash(black:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ],
    "deny": [
      "Read(./config.env)",
      "Read(./.env)",
      "Edit(./config.env)",
      "Edit(./.env)"
    ]
  }
}
