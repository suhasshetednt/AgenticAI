# ADL Automated Delivery Pipeline — environment template.
# Copy this file to `config.env` (or `.env`) and fill in real values.
# config.env / .env are git-ignored; this .example file is safe to commit.

# ── Jira (required) ───────────────────────────────────────────────────────────
JIRA_INSTANCE_URL=https://your-org.atlassian.net
JIRA_USERNAME=you@example.com
JIRA_API_TOKEN=your-jira-api-token
DEFAULT_PROJECT=ADL

# ── LLM provider (Claude is primary) ──────────────────────────────────────────
# PRIMARY_LLM selects the preferred provider: claude | gemini | openai
PRIMARY_LLM=claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Optional fallbacks — leave blank to disable.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Dremio ────────────────────────────────────────────────────────────────────
dremio_url=https://api.eu.dremio.cloud
dremio_username=you@example.com
DREMIO_TOKEN=your-dremio-token
DREMIO_PROJECT_ID=your-dremio-project-id
DREMIO_CATALOG_ID=your-dremio-catalog-id
DREMIO_CATALOG_NAME=dremio-db
# Directory containing catalog_data.json / excel_master.json (table & column
# catalog used for SQL generation). Defaults to the project root if unset.
# CATALOG_DIR=D:\path\to\catalog

# ── Qlik Sense Cloud (optional) ───────────────────────────────────────────────
QLIK_TENANT=https://your-tenant.qlikcloud.com
QLIK_API_KEY=your-qlik-api-key
QLIK_SPACE=development

# ── GitHub (optional) ─────────────────────────────────────────────────────────
GITHUB_USERNAME=your-github-username
GITHUB_TOKEN=ghp_your-github-token

# ── Webhook ───────────────────────────────────────────────────────────────────
JIRA_WEBHOOK_SECRET=change-me-to-a-strong-secret
WEBHOOK_AUTO_PROCESS=true
WEBHOOK_REQUIRE_APPROVAL=true

# ── API security ──────────────────────────────────────────────────────────────
API_SECRET_KEY=change-me-in-production
ENV=development
