-- VDS: APU Health Monitor
-- Description: APU performance data from AMOS for APUs fitted to ASL AC Type B737NG aircraft
-- Source: amos_postgres.amos (rotables, rotables_trend, aircraft)
-- Owner: Engine Folder
-- Ticket: ADL-1700

WITH apu_latest_trend AS (
  SELECT
    rt.psn,
    rt.ref_date,
    rt.trend_type,
    rt."value",
    rt.event_perfno_i,
    ROW_NUMBER() OVER (PARTITION BY rt.psn ORDER BY rt.ref_date DESC) AS rn
  FROM amos_postgres.amos.rotables_trend rt
  WHERE UPPER(rt.trend_type) = UPPER('CT5')
    AND rt.ref_date IS NOT NULL
)
SELECT
  r.partno,
  r.serialno,
  r.psn,
  r.ac_registr,
  alt.psn AS rt_psn,
  DATE_ADD(DATE '1971-12-31', CAST(alt.ref_date AS BIGINT)) AS ref_date,
  alt.trend_type,
  alt.event_perfno_i,
  alt."value",
  a.ac_typ
FROM amos_postgres.amos.rotables r
INNER JOIN apu_latest_trend alt
  ON r.psn = alt.psn
  AND alt.rn = 1
LEFT JOIN amos_postgres.amos.aircraft a
  ON UPPER(r.ac_registr) = UPPER(a.ac_registr)
WHERE UPPER(a.ac_typ) = UPPER('B737NG')

